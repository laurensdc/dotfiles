  {
    "context": "vim_mode == insert",
    "unbind": {
      "ctrl-t": "vim::Indent"
    }
  },
  {
    "context": "vim_mode == literal",
    "unbind": {
      "ctrl-t": [
        "vim::Literal",
        [
          "ctrl-t",
          "\u0014"
        ]
      ]
